# Dependências Node.js
# Ignora as pastas node_modules em todos os níveis do projeto
node_modules/
backend/node_modules/
frontend/node_modules/

# Arquivos de ambiente
# Protege informações sensíveis como senhas e chaves de API
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Builds e distribuições
# Ignora arquivos gerados durante o build do frontend
frontend/dist/

# Logs de erro
# Arquivos de log gerados pelo npm ou yarn
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Arquivos de sistema
# Arquivos específicos do sistema operacional
.DS_Store
Thumbs.db

# IDE - Visual Studio Code
# Configurações específicas do editor
.vscode/